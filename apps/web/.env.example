# Public anon key (safe in the browser). Copy to `.env` for local dev.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Optional: override magic-link base URL (preview / staging). Production builds default to https://nomisocial.xyz
# unless you set this to a non-localhost URL (localhost is ignored in NODE_ENV=production).
# NUXT_PUBLIC_SITE_URL=https://your-preview.vercel.app

# Supabase Dashboard → Auth → URL Configuration: add redirect URL e.g.
# http://localhost:3000/auth/confirm and your production /auth/confirm

# --- Dev testing without email (magic link / SMTP) ---
# 1. Supabase → Authentication → Users → Add user → set email + password (user is confirmed).
# 2. pnpm dev → open http://localhost:3000/dev/login — only works in development (disabled in prod build).
